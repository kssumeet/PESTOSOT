# ─────────────────────────────────────────────────────────────
# PESTOSOT — root env example (copy per-app, see apps/*/.env.example)
# This file documents the full set; each app reads its own .env.
# ─────────────────────────────────────────────────────────────

# ---- apps/api ----
DATABASE_URL="postgresql://pestosot:pestosot@localhost:5544/pestosot?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
API_PORT="4000"
WEB_ORIGIN="http://localhost:3000"

# Seed admin (created by `bun run --filter api seed`)
SEED_ADMIN_EMAIL="admin@pestosot.com"
SEED_ADMIN_PASSWORD="Admin@12345"

# SMTP (Nodemailer) — leave blank to log emails to console in dev
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="PESTOSOT <no-reply@pestosot.com>"
LEAD_NOTIFY_TO="bookings@pestosot.com"

# ---- apps/web ----
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
