# ── PESTOSOT API — production env (set these in Railway/Render, NOT committed) ──

NODE_ENV=production
API_PORT=4000

# Hosted Postgres (Railway plugin / Neon / Supabase). Include sslmode=require for managed DBs.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require

# REQUIRED: 32+ char random secret. The API refuses to boot in production without it.
# Generate: openssl rand -hex 48
JWT_SECRET=replace-with-a-64-char-random-secret
JWT_EXPIRES_IN=7d

# The deployed frontend origin (for CORS + cookies).
WEB_ORIGIN=https://your-frontend.vercel.app

# ── Cookie scoping ──
# Same parent domain (api.pestosot.com + pestosot.com): set COOKIE_DOMAIN=.pestosot.com
#   and leave COOKIE_SAMESITE unset (defaults to strict — most secure).
# Different domains (*.vercel.app + *.railway.app): set COOKIE_SAMESITE=none.
COOKIE_SAMESITE=none
# COOKIE_DOMAIN=.pestosot.com

# Seed admin (run `bun run seed` once after first deploy)
SEED_ADMIN_EMAIL=admin@pestosot.com
SEED_ADMIN_PASSWORD=change-this-to-a-strong-password

# SMTP (leave blank to log lead emails to the server console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=PESTOSOT <no-reply@pestosot.com>
LEAD_NOTIFY_TO=bookings@pestosot.com
