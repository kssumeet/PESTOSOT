generator client {
  provider      = "prisma-client-js"
  // "native" for local/Docker; "rhel-openssl-3.0.x" for the Vercel/AWS Lambda runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  SALES
  CONTENT
  EDITOR
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SCHEDULED
  WON
  LOST
  CLOSED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(SALES)
  isActive     Boolean  @default(true)
  leads        Lead[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String
  passwordHash String
  leads        Lead[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Lead {
  id            String     @id @default(cuid())
  name          String
  phone         String
  email         String?
  serviceType   String
  propertyType  String
  city          String     @default("Bangalore")
  locality      String?
  preferredDate DateTime?
  preferredTime String?
  message       String?
  source        String     @default("website")
  status        LeadStatus @default(NEW)
  assignedToId  String?
  assignedTo    User?      @relation(fields: [assignedToId], references: [id])
  customerId    String?
  customer      Customer?  @relation(fields: [customerId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
}

model Service {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  category  String
  shortDesc String
  isPopular Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Location {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  city      String   @default("Bangalore")
  createdAt DateTime @default(now())
}
